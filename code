<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>The Archive</title>

<link href="https://fonts.googleapis.com/css2?family=Hubballi&family=Kanit:wght@300;400;500&display=swap" rel="stylesheet">

<style>

:root{
    --bg:#faf8f4;
    --card:#f2ede6;
    --border:#d8d4cc;
    --slate:#64748b;
    --text:#374151;
    --muted:#7b8794;
}

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    background:var(--bg);
    color:var(--text);
    font-family:'Kanit',sans-serif;
    min-height:100vh;
}

.container{
    max-width:1000px;
    margin:auto;
    padding:50px 25px;
}

.hero{
    background:var(--card);
    border:1px solid var(--border);
    border-radius:28px;
    padding:45px;
    margin-bottom:35px;
}

.hero h1{
    font-family:'Hubballi',cursive;
    font-size:5rem;
    color:var(--slate);
    line-height:1;
}

.hero p{
    margin-top:15px;
    color:var(--muted);
    max-width:600px;
}

.section-title{
    color:var(--slate);
    margin-bottom:15px;
    font-size:1.1rem;
    font-weight:500;
}

.card{
    background:white;
    border:1px solid var(--border);
    border-radius:24px;
    padding:25px;
    margin-bottom:20px;
}

.month-header{
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-bottom:20px;
}

.month-name{
    font-size:1.7rem;
    color:var(--slate);
    font-weight:500;
}

.entry{
    padding:12px;
    border-left:3px solid var(--slate);
    margin-bottom:10px;
    background:#fcfbf8;
    border-radius:0 12px 12px 0;
}

.entry-type{
    font-size:.75rem;
    text-transform:uppercase;
    letter-spacing:1px;
    color:var(--muted);
}

.entry-text{
    margin-top:5px;
}

.form{
    display:grid;
    gap:10px;
    margin-bottom:30px;
}

select,
textarea,
button{
    font-family:'Kanit',sans-serif;
}

select,
textarea{
    border:1px solid var(--border);
    border-radius:14px;
    padding:12px;
    background:white;
}

textarea{
    resize:none;
    height:90px;
}

button{
    border:none;
    background:var(--slate);
    color:white;
    padding:12px;
    border-radius:14px;
    cursor:pointer;
    transition:.2s;
}

button:hover{
    opacity:.9;
}

.timeline{
    position:relative;
}

.timeline::before{
    content:"";
    position:absolute;
    left:15px;
    top:0;
    bottom:0;
    width:2px;
    background:var(--border);
}

.month{
    position:relative;
    margin-left:35px;
}

.month::before{
    content:"";
    position:absolute;
    left:-28px;
    top:25px;
    width:12px;
    height:12px;
    border-radius:50%;
    background:var(--slate);
}

.empty{
    color:var(--muted);
    font-style:italic;
}

.footer{
    text-align:center;
    margin-top:40px;
    color:var(--muted);
    font-size:.9rem;
}

@media(max-width:700px){

.hero h1{
    font-size:3.5rem;
}

.month-header{
    flex-direction:column;
    align-items:flex-start;
}

}

</style>
</head>
<body>

<div class="container">

<div class="hero">
    <h1>The Archive</h1>
    <p>
        A collection of moments, achievements, memories,
        funny quotes, and things worth remembering.
    </p>
</div>

<div class="card">

    <div class="section-title">Add an Entry</div>

    <div class="form">

        <select id="type">
            <option>Achievement</option>
            <option>Memory</option>
            <option>Quote</option>
            <option>Reflection</option>
            <option>Favorite</option>
        </select>

        <textarea id="text"
        placeholder="Write something worth remembering..."></textarea>

        <button onclick="addEntry()">
            Add to June 2026
        </button>

    </div>

</div>

<div class="timeline">

<div class="month card">

<div class="month-header">
    <div class="month-name">June 2026</div>
</div>

<div id="entries"></div>

</div>

</div>

<div class="footer">
    The small things are usually the things you'll forget first.
</div>

</div>

<script>

let entries =
JSON.parse(localStorage.getItem("archiveEntries")) || [];

function render(){

const container =
document.getElementById("entries");

container.innerHTML="";

if(entries.length===0){

container.innerHTML=
'<div class="empty">No entries yet.</div>';

return;
}

entries.forEach(item=>{

const div=document.createElement("div");

div.className="entry";

div.innerHTML=`
<div class="entry-type">${item.type}</div>
<div class="entry-text">${item.text}</div>
`;

container.appendChild(div);

});

}

function addEntry(){

const type=
document.getElementById("type").value;

const text=
document.getElementById("text").value.trim();

if(!text) return;

entries.unshift({
type,
text
});

localStorage.setItem(
"archiveEntries",
JSON.stringify(entries)
);

document.getElementById("text").value="";

render();

}

render();

</script>

</body>
</html>
